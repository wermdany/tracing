{
  "name": "@tracing/browser-http-axios",
  "version": "0.0.4",
  "private": false,
  "lib": true,
  "description": "Axios HTTP request monitoring plugin for tracing SDK",
  "main": "index.js",
  "module": "dist/browser-http-axios.esm-bundler.js",
  "types": "dist/browser-http-axios.d.ts",
  "sideEffects": false,
  "author": "wermdany <https://github.com/wermdany>",
  "license": "ISC",
  "files": [
    "dist",
    "index.js"
  ],
  "buildOptions": {
    "name": "BrowserHttpAxios",
    "formats": [
      "esm-bundler",
      "esm-browser",
      "cjs",
      "global"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wermdany/tracing.git",
    "directory": "packages/browser-http-axios"
  },
  "bugs": {
    "url": "https://github.com/wermdany/tracing/issues"
  },
  "homepage": "https://github.com/wermdany/tracing/tree/master/packages/browser-http-axios#readme",
  "keywords": [
    "collect",
    "tracker",
    "report",
    "FE",
    "web",
    "axios"
  ],
  "dependencies": {
    "@tracing/core": "workspace:*",
    "@tracing/shared": "workspace:*"
  },
  "devDependencies": {
    "axios": "^1.6.8"
  },
  "peerDependencies": {
    "axios": "^1.x"
  }
}
